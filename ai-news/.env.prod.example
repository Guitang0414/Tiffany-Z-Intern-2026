# ai-news PRODUCTION env — set these in the Dokploy "Environment" tab (NOT committed).
# Generate secrets with: openssl rand -base64 32

# --- Directus core ---
DIRECTUS_KEY=
DIRECTUS_SECRET=
PUBLIC_URL=https://cms.epochtimesnw.com   # the domain mentor assigns

# --- Postgres (self-contained) ---
POSTGRES_USER=directus
POSTGRES_PASSWORD=
POSTGRES_DB=directus

# --- Phase 1 bootstrap admin (drop once Authentik OIDC is on) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Hooks: service-account role id(s) ---
# Leave EMPTY for the first deploy. After running bootstrap/permissions.mjs against the
# live instance, it prints the service role id — paste it here and redeploy. (DEPLOY.md step 6)
ARTICLES_SERVICE_ROLE_IDS=

# --- Authentik OIDC (Phase 2; fill from the Authentik application mentor creates) ---
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER_URL=https://auth.epochtimesnw.com/application/o/directus-cms/
# DIRECTUS_DEFAULT_ROLE_ID=

# --- Hermes Agent(抓取 worker)---
HERMES_DIRECTUS_URL=https://cms.epochtimesnw.com   # agent 写入的 Directus(公网域名,因 host 网络)
HERMES_DIRECTUS_TOKEN=                              # service 账号静态 token(禁用 admin)
GATEWAY_BASE_URL=http://100.97.116.16:8317/v1       # Claude 网关 tailnet IP(host 网络下可达)
GATEWAY_API_KEY=                                    # 网关 key
JINA_API_KEY=                                       # Jina 免费 key(500 RPM)
# MODEL_DEEP=claude-sonnet-4-6
# MODEL_SHORT=claude-haiku-4-5-20251001
