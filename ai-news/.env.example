# ai-news local DEV environment
# Copy to .env and fill in. .env is gitignored. DEV ONLY — never points at prod.

# --- Directus core ---
# Generate with: openssl rand -base64 32
DIRECTUS_KEY=replace-with-random-uuid
DIRECTUS_SECRET=replace-with-random-string
PUBLIC_URL=http://localhost:8055

# --- Local admin (dev login; prod uses Authentik OIDC instead) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-locally

# --- Postgres (self-contained, per deployment-plan: Directus owns the business DB) ---
POSTGRES_USER=directus
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=directus

# --- Service-account role IDs (comma-separated Directus role UUIDs) ---
# Agent + n8n tokens use these roles. The articles hooks treat them as actor="service":
# they may only do PUBLISHING->PUBLISHED/FAILED + FAILED->PUBLISHING, and can never set reviewed_by.
# Fill in after the bootstrap script creates the roles (see bootstrap/README.md).
ARTICLES_SERVICE_ROLE_IDS=
