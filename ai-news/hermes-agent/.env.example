# Hermes Agent 配置 — 复制为 .env 填好。.env 不进 git。

# --- Directus(写入目标 + service token,禁用 admin) ---
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=svc-static-token-123          # service 账号静态 token(本地 bootstrap 种的)

# --- Claude 网关(OpenAI 兼容,Tailscale) ---
GATEWAY_BASE_URL=http://seattle-eet-lenovo-product:8317/v1
GATEWAY_API_KEY=                              # 网关 key
MODEL_DEEP=claude-sonnet-4-6                  # Lane A 深度长文
MODEL_SHORT=claude-haiku-4-5-20251001         # Lane B 短讯

# --- Jina Reader(取材) ---
JINA_API_KEY=                                 # 免费 key(500 RPM);留空则 keyless(~20 RPM)
JINA_MIN_INTERVAL_MS=1500                     # 两次 Jina 调用最小间隔(限流兜底)

# --- 调度(自带 cron) ---
CRON_HIGH=*/10 * * * *                        # 高频:Lane B 热点短讯
CRON_LOW=0 8 * * *                            # 低频:Lane A 本地深度(每天 8 点)
TZ=America/Los_Angeles

# --- 预算 / 存储 ---
DAILY_TOKEN_BUDGET=500000                     # Claude 每日 token 上限,超了 hard-fail
SQLITE_PATH=./cache/hermes.db                 # 重试/防丢/预算 持久化
MAX_PER_RUN=8                                 # 每轮每个 lane 最多处理几篇(控量)

LOG_LEVEL=info
